{
  "name": "@vasekzdvihal/eslint-config",
  "version": "0.1.1",
  "description": "Shared ESLint flat config for Vasek's Vue/Nuxt/TS projects. Wraps @antfu/eslint-config with personal style and AI guardrails.",
  "type": "module",
  "license": "MIT",
  "author": "Vasek Zdvihal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasekzdvihal/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/vasekzdvihal/eslint-config/issues"
  },
  "homepage": "https://github.com/vasekzdvihal/eslint-config#readme",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "vue",
    "nuxt",
    "typescript",
    "antfu"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.js",
    "./vue": "./src/vue.js",
    "./strict": "./src/strict.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test 'tests/**/*.test.js'",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "peerDependencies": {
    "eslint": "^9.10.0 || ^10.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1"
  },
  "devDependencies": {
    "eslint": "^9.10.0"
  }
}
